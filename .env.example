# =============================================
# Telegram Bot — Event Registration Template
# =============================================
# Copy this file to .env and fill in your values.
# Required: BOT_TOKEN
# Optional: everything else (integrations degrade gracefully)

# ── Telegram ──────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram User IDs who get admin access
ADMIN_IDS=111222333,444555666

# ── Manager Contact ───────────────────────
# Telegram username (without @) for /manager link
MANAGER_USERNAME=your_manager_username

# ── Welcome & Branding ────────────────────
BOT_WELCOME_TEXT=Добро пожаловать! Выберите действие:

# ── UI: Button Labels ─────────────────────
# Emojis are part of the value — change them to customise the look
BTN_EVENTS=📅 Мероприятия
BTN_PROGRAMS=📚 Программы
BTN_MANAGER=👤 Менеджер
BTN_FAQ=❓ FAQ
BTN_ADMIN=⚙️ Админ
BTN_HOME=Домой
BTN_REGISTER=✍️ Зарегистрироваться
BTN_BACK=Назад
BTN_CANCEL=Отмена
BTN_WRITE_MANAGER=Написать менеджеру
BTN_SHARE_CONTACT=Поделиться контактом

# Admin panel buttons
BTN_ADMIN_STATS=📊 Статистика
BTN_ADMIN_BROADCAST=📢 Рассылка
BTN_ADMIN_REMINDERS=⏰ Напоминания
BTN_ADMIN_FAQ=❓ Управление FAQ
BTN_ADMIN_FAQ_VIEW=Просмотр
BTN_ADMIN_FAQ_EDIT=Редактировать
BTN_SEND_CONFIRM=✅ Отправить

# ── UI: Messages ──────────────────────────
# Registration flow
MSG_REG_COMPANY=Регистрация: {item_name}\n\nВведите название вашей компании:
MSG_REG_COMPANY_EMPTY=Поле не может быть пустым. Введите название компании:
MSG_REG_COMPANY_LONG=Слишком длинное название (макс. 255 символов). Повторите:
MSG_REG_POSITION=Отлично! Теперь введите вашу должность:
MSG_REG_POSITION_EMPTY=Поле не может быть пустым. Введите должность:
MSG_REG_POSITION_LONG=Слишком длинное поле (макс. 255 символов). Повторите:
MSG_REG_EMAIL=Теперь введите ваш email:
MSG_REG_EMAIL_EMPTY=Введите ваш email:
MSG_REG_EMAIL_INVALID=Неверный формат email. Попробуйте ещё раз:
MSG_REG_CODE_WORD=Введите кодовое слово для подтверждения участия:
MSG_REG_CODE_OK=Код подтверждён!
MSG_REG_CODE_FAIL_3=Неверный код (3 попытки исчерпаны). Обратитесь к менеджеру.
MSG_REG_CODE_FAIL_REMAINING=Неверный код. Осталось попыток: {remaining}
MSG_REG_CONFIRM=✅ Регистрация завершена!\n\nМероприятие: <b>{item_name}</b>\nИмя: {first_name} {last_name}\nEmail: {email}\n\nМы свяжемся с вами для подтверждения.
MSG_REG_ERROR_EVENT=Ошибка: мероприятие не найдено.
MSG_REG_ERROR_EVENT_ID=Ошибка ID мероприятия.
MSG_REG_ERROR_PROGRAM=Ошибка: программа не найдена.
MSG_REG_ERROR_PROGRAM_ID=Ошибка ID программы.

# Events & Programs
MSG_NO_EVENTS=📅 Пока нет предстоящих мероприятий.\nСледите за обновлениями!
MSG_EVENTS_TITLE=📅 Афиша мероприятий:
MSG_EVENT_NOT_FOUND=Мероприятие не найдено.
MSG_NO_PROGRAMS=📚 Пока нет доступных программ.\nСледите за обновлениями!
MSG_PROGRAMS_TITLE=📚 Программы обучения:
MSG_PROGRAM_NOT_FOUND=Программа не найдена.

# Admin panel
MSG_ADMIN_TITLE=Панель администратора:
MSG_ADMIN_NO_ACCESS=У вас нет прав администратора.
MSG_ADMIN_BACK_TEXT=Панель администратора:
MSG_NO_ADMIN_EVENTS=Нет предстоящих мероприятий в ближайшие 30 дней.
MSG_ADMIN_REMINDERS_TITLE=⏰ Напоминания\nВыберите мероприятие:
MSG_BROADCAST_PROMPT=📢 Рассылка\n\nВведите текст для рассылки всем пользователям:
MSG_BROADCAST_CONFIRM=Подтвердите рассылку:\n\n{text}
MSG_BROADCAST_SENT=✅ Рассылка отправлена\n\n{text}
MSG_FAQ_MANAGE_TITLE=❓ Управление FAQ
MSG_FAQ_EDIT_PROMPT=Введите новый текст для FAQ:
MSG_FAQ_SAVED=FAQ обновлён!

# Contact / FAQ
MSG_MANAGER_CONTACT=Связаться с менеджером: @{manager}
MSG_CONTACT_PROMPT=Мы хотим вас запомнить и будем рады, если вы поделитесь контактом, нажав кнопку ниже.
MSG_CONTACT_THANKS=Спасибо, {first_name}! Мы вас запомнили.
FAQ_FALLBACK_TEXT=FAQ временно в разработке, возвращайтесь чуточку позже.

# ── Google Sheets (optional) ──────────────
# Leave empty to use local Excel fallback
GOOGLE_SHEET_ID_USERS=
GOOGLE_SHEET_ID_EVENTS=
GOOGLE_SHEET_ID_PROGRAMS=
GOOGLE_SHEET_ID_REGISTRATIONS=
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# ── Bitrix24 CRM (optional) ───────────────
BITRIX_WEBHOOK_URL=
BITRIX_CATEGORY_ID=17
BITRIX_STAGE_ID=NEW
# Custom field IDs — update to match your Bitrix pipeline
BITRIX_FIELD_PHONE=
BITRIX_FIELD_EMAIL=
BITRIX_FIELD_COMPANY=
BITRIX_FIELD_POSITION=
BITRIX_FIELD_CODE_STATUS=

# ── Payments (optional) ───────────────────
PAYMENT_URL=https://example.com/pay
